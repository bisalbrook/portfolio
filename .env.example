# --- Site ---
# Used for absolute URLs in metadata, OG images, and the sitemap.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# --- GitHub page (optional) ---
# If set, the /github page fetches live profile + repo data instead of using
# the bundled sample data in data/repositories.json.
GITHUB_USERNAME=
# Optional, only needed to raise the GitHub API rate limit.
GITHUB_TOKEN=

# --- Contact form / EmailJS (optional) ---
# Create a free account at https://www.emailjs.com to get these three values.
# Without them, the contact form still validates and shows a success toast
# in a simulated "dev mode" — it just won't actually send an email.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
